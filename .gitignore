# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
*.egg
pip-wheel-metadata/

# ── Virtual environment ───────────────────────────────────────────────
.venv/
venv/
env/

# ── PyInstaller artefacts ─────────────────────────────────────────────
# terraai.spec IS committed; generated outputs are not
dist/
build/

# ── Environment / secrets ─────────────────────────────────────────────
.env
.env.*
*.key
*.pem
secrets.yaml

# ── TerraAI runtime files ─────────────────────────────────────────────
.terraai/
*.enc

# ── Terraform (guard against accidental tf runs in the source dir) ────
.terraform/
.terraform.lock.hcl
tfplan
*.tfvars
terraform.tfstate
terraform.tfstate.backup
backend.tf
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ── OS metadata ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor ────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# tiktoken BPE files — downloaded by build.sh / CI before pyinstaller runs
tiktoken_cache/

# Generated by install.sh — machine-specific, never commit
terraai
